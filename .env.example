# ════════════════════════════════════════════════════════════
#  AI Crypto Trading System — 환경변수 설정 파일
#  cp .env.example .env  후 실제 값으로 교체하세요.
# ════════════════════════════════════════════════════════════

# ── Mock 모드 ──────────────────────────────────────────────
MOCK_MODE=true
MOCK_SCENARIO=default          # default | bullish | bearish

# ── Bybit API ─────────────────────────────────────────────
BYBIT_API_KEY=your_bybit_api_key_here
BYBIT_API_SECRET=your_bybit_api_secret_here
BYBIT_TESTNET=true             # 반드시 true로 시작, 검증 후 false 전환

# ── Ollama (full 모드만) ───────────────────────────────────
# Docker 내부: http://ollama:11434 (docker-compose.yml 자동 주입)
# 외부 접근 시 오버라이드: http://host.docker.internal:11434
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2

# ── OpenClaw Gateway ──────────────────────────────────────
# 이미지 태그 (latest 또는 main)
OPENCLAW_IMAGE=alpine/openclaw:latest

# 게이트웨이 포트
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_BRIDGE_PORT=18790

# ★ 게이트웨이 인증 토큰 — 강력한 랜덤 문자열로 교체하세요
#   예: openssl rand -hex 32
OPENCLAW_GATEWAY_TOKEN=change_this_to_a_strong_random_token

# Trading API → OpenClaw 알림 토큰 (OPENCLAW_GATEWAY_TOKEN 과 동일하게 설정)
OPENCLAW_TOKEN=change_this_to_a_strong_random_token

# Docker 내부: http://openclaw-gateway:18789 (docker-compose 자동 주입)
# 단독 실행 시 오버라이드: http://host.docker.internal:18789
OPENCLAW_URL=http://openclaw-gateway:18789

# ── OpenClaw LLM 자격증명 (optional) ─────────────────────
# OpenAI API 키 (GPT 에이전트 사용 시)
OPENAI_API_KEY=

# Claude Web 세션 (Claude.ai 세션 사용 시 — 선택)
CLAUDE_AI_SESSION_KEY=
CLAUDE_WEB_SESSION_KEY=
CLAUDE_WEB_COOKIE=

# ── Webhook ────────────────────────────────────────────────
# ★ 웹훅 인증 토큰 — OpenClaw cron이 POST /webhook/news 호출 시 사용
#   예: openssl rand -hex 24
WEBHOOK_TOKEN=change_this_to_a_strong_random_token

# ── Score Thresholds ──────────────────────────────────────
SCORE_NOTIFY_MIN=10
SCORE_AUTO_TRADE_MIN=20

# ── Risk Management ───────────────────────────────────────
MAX_DAILY_LOSS_PCT=3.0
MAX_POSITION_PCT=10.0
MAX_CONSECUTIVE_LOSSES=5

# ── Database ──────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./data/trading.db

# ── Notifications ─────────────────────────────────────────
# Telegram
TELEGRAM_BOT_TOKEN=          # optional: 텔레그램 봇 토큰
TELEGRAM_CHAT_ID=            # optional: 텔레그램 채팅 ID

# Discord
DISCORD_WEBHOOK_URL=         # optional: 디스코드 웹훅 URL

# ── Scheduler ────────────────────────────────────────────
SCHEDULE_INTERVAL_MIN=30     # 내부 APScheduler 간격 (분)
NEWS_LOOKBACK_HOURS=2
WATCH_SYMBOLS=BTCUSDT,ETHUSDT

# ── Logging ───────────────────────────────────────────────
LOG_LEVEL=INFO
