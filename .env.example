# ── Mock ──────────────────────────────────────────────
MOCK_MODE=true
MOCK_SCENARIO=default          # default | bullish | bearish

# ── Bybit API ─────────────────────────────────────────
BYBIT_API_KEY=your_api_key_here
BYBIT_API_SECRET=your_api_secret_here
BYBIT_TESTNET=true

# ── Ollama ────────────────────────────────────────────
OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.2          # pull 후 사용할 모델명

# ── OpenClaw ──────────────────────────────────────────
OPENCLAW_URL=http://host.docker.internal:18789
OPENCLAW_TOKEN=my_super_secret_token_123

# ── Score Thresholds ──────────────────────────────────
SCORE_NOTIFY_MIN=10
SCORE_AUTO_TRADE_MIN=20

# ── Risk Management ───────────────────────────────────
MAX_DAILY_LOSS_PCT=3.0
MAX_POSITION_PCT=10.0
MAX_CONSECUTIVE_LOSSES=5

# ── Database ──────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./data/trading.db

# ── Notifications ─────────────────────────────────────
TELEGRAM_BOT_TOKEN=          # optional: 텔레그램 봇 토큰
TELEGRAM_CHAT_ID=            # optional: 텔레그램 채팅 ID
DISCORD_WEBHOOK_URL=         # optional: 디스코드 웹훅 URL

# ── Scheduler ────────────────────────────────────────
SCHEDULE_INTERVAL_MIN=30
NEWS_LOOKBACK_HOURS=2
WATCH_SYMBOLS=BTCUSDT,ETHUSDT
WEBHOOK_TOKEN=your_webhook_token_here

# ── Logging ───────────────────────────────────────────
LOG_LEVEL=INFO
